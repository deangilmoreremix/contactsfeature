# SmartCRM Environment Variables
# Copy this file to .env and fill in your actual values

# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# AgentMail API Configuration
AGENTMAIL_API_KEY=your_agentmail_api_key_here
AGENTMAIL_DEFAULT_INBOX_ID=your_default_inbox_id_here
AGENTMAIL_INBOX_DEAN=your_dean_inbox_id_here
AGENTMAIL_INBOX_SARAH=your_sarah_inbox_id_here
AGENTMAIL_INBOX_TECH=your_tech_inbox_id_here

# SDR Assistant Configuration (optional - will be auto-created if not set)
SDR_ASSISTANT_ID=your_openai_assistant_id_here

# Supabase Database Configuration
# For Netlify: Set these in Netlify Dashboard → Environment Variables
# IMPORTANT: VITE_ prefix is required for frontend build-time variables
SUPABASE_URL=https://bzxohkrxcwodllketcpz.supabase.co
SUPABASE_ANON_KEY=sb_publishable_-CX9glOjtolD9mPJqjHlaQ_bFxkQZn6
# SUPABASE_SERVICE_ROLE_KEY=sb_secret_uj4ETD63Ilkp4ElAyKSpjw_8wLbLWeN  # Set in Netlify only (never expose to frontend)

# Netlify URL (auto-populated in production)
URL=https://your-netlify-site.netlify.app

# AI Model Configuration (GPT-5.2 Upgrade)
SMARTCRM_MODEL=gpt-5.2
SMARTCRM_THINKING_MODEL=gpt-5.2-thinking
SMARTCRM_FAST_MODEL=gpt-5.2-instant
