# pnpm configuration for Netlify CI
# Allow build scripts for packages that need native compilation (pnpm 11+)
unsafe.builders=@parcel/watcher,esbuild,core-js-pure,netlify-cli,sharp,unix-dgram,unrs-resolver
allowed-scripts=@parcel/watcher,esbuild,core-js-pure,netlify-cli,sharp,unix-dgram,unrs-resolver

# Enable pnpm 11+ strict mode compatibility
ignore-workspace-cycle=true

# Auto-approve all build scripts for CI
auto-install-peers=true
strict-peer-dependencies=false

# pnpm settings
node-linker=node-modules
virtual-store-dir=node_modules/.pnpm
